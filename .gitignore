# Keep settings.json tracked — site config changes should deploy.
# Uncomment if you want per-env settings instead:
# data/settings.json

# ── React build outputs (when committed at repo root for deploy) ──
# During migration we leave the PHP frontend live, so these are not yet
# at the root. When we do flip the switch, these will exist at root and
# should be COMMITTED (Hostinger serves them). Until then they don't exist,
# so these lines are harmless.
# /_next/
# /out/

# ── React project's own build artifacts ──────────────────────
ansar-next/node_modules/
ansar-next/.next/
ansar-next/out/
ansar-next/*.tsbuildinfo

