# ── ANSAR MAHMOOD — Apache Configuration (React SPA + PHP backend) ─────

Options -Indexes
Options +FollowSymLinks
RewriteEngine On
RewriteBase /Ansar/

# ── Security Headers ────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# ── Gzip Compression ────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
  AddOutputFilterByType DEFLATE application/xml image/svg+xml
</IfModule>

# ── Browser Caching ─────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                 "access plus 0 seconds"
  ExpiresByType text/css                  "access plus 1 month"
  ExpiresByType application/javascript    "access plus 1 month"
  ExpiresByType image/png                 "access plus 6 months"
  ExpiresByType image/jpg                 "access plus 6 months"
  ExpiresByType image/jpeg                "access plus 6 months"
  ExpiresByType image/gif                 "access plus 6 months"
  ExpiresByType image/svg+xml             "access plus 6 months"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
</IfModule>

# ── Block direct browsing of data/ (but Vite/React imports JSON at build
#    time, so runtime access isn't needed for the SPA). PHP in forms/ must
#    still be reachable for form submissions.
RewriteRule ^data/.*\.json$ - [F,L]

# ── Hotlink protection for images ───────────────────────────────
RewriteCond %{HTTP_REFERER} !^$ [NC]
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?ansarmahmood\.com [NC]
RewriteCond %{HTTP_REFERER} !^https?://mransarmahmood\.github\.io [NC]
RewriteCond %{HTTP_REFERER} !^https?://localhost [NC]
RewriteCond %{HTTP_REFERER} !^https?://127\.0\.0\.1 [NC]
RewriteRule \.(jpg|jpeg|png|gif|pdf)$ - [F,NC,L]

# ── SPA Routing ─────────────────────────────────────────────────
# 1. Let Apache serve real files (index.html, assets/*, images, etc.)
# 2. Let Apache execute PHP handlers normally (forms/*.php, exam-*.php, admin/*)
# 3. Anything else (e.g. /Ansar/about, /Ansar/services) → fall through to
#    index.html so React Router can resolve the route client-side.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule .* - [L]

RewriteRule \.php$ - [L]

RewriteRule ^ index.html [L]
