<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 268 56" fill="none" role="img" aria-label="Ansar Mahmood Logo">
  <!-- Shield mark - represents protection & safety -->
  <path d="M28 3 L52 13 L52 33 C52 46 41 53 28 55 C15 53 4 46 4 33 L4 13 Z" fill="#0B1D36"/>
  <path d="M28 11 L45 19 L45 33 C45 43 37 48 28 50 C19 48 11 43 11 33 L11 19 Z" fill="#B87E18"/>
  <!-- A letter -->
  <text x="28" y="37" text-anchor="middle" font-family="'Arial Black', Arial, Helvetica, sans-serif" font-weight="900" font-size="15" fill="#FFFFFF" letter-spacing="-0.5">AM</text>

  <!-- Vertical rule separator -->
  <line x1="64" y1="12" x2="64" y2="44" stroke="#C8D4E8" stroke-width="1" stroke-linecap="round"/>

  <!-- Name wordmark -->
  <text x="76" y="27" font-family="Arial, Helvetica, sans-serif" font-weight="800" font-size="18" fill="#0B1D36" letter-spacing="0.6">ANSAR MAHMOOD</text>

  <!-- Tagline -->
  <text x="77" y="43" font-family="Arial, Helvetica, sans-serif" font-weight="500" font-size="9.5" fill="#B87E18" letter-spacing="2.8">HSE  ·  DIGITAL  ·  AI</text>
</svg>
