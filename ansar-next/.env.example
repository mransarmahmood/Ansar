# ── Search engine verification tokens ─────────────────────────
# Paste values from each platform after copying them. Rebuild to apply.
# None of these are secret — they only prove domain ownership.

# Google Search Console — from "HTML tag" verification method
# https://search.google.com/search-console
NEXT_PUBLIC_GSC_TOKEN=

# Bing Webmaster Tools — "Meta tag" verification method
# https://www.bing.com/webmasters
NEXT_PUBLIC_BING_TOKEN=

# Yandex Webmaster — optional, useful for Russian/CIS traffic
# https://webmaster.yandex.com
NEXT_PUBLIC_YANDEX_TOKEN=
